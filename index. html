# ============================================================================
# Admin: Orders & Customers & Analytics
# ============================================================================
class StatusUpdate(BaseModel):
    status: Literal[\"pending\", \"confirmed\", \"preparing\", \"out_for_delivery\", \"delivered\", \"cancelled\"]
    note: str = \"\"


