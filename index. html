    if not o:
        raise HTTPException(404, \"Not found\")
    history = o.get(\"status_history\", [])
    history.append({\"status\": upd.status, \"at\": now_iso(), \"note\": upd.note or f\"Status changed to {upd.status}\"})
    await db.orders.update_one(
        {\"id\": order_id},
        {\"$set\": {\"status\": upd.status, \"status_history\": history, \"updated_at\": now_iso()}},
    )
    return await db.orders.find_one({\"id\": order_id}, {\"_id\": 0})


@api.get(\"/admin/customers\")
async def admin_customers(_=Depends(admin_user)):
    users = await db.users.find({\"role\": \"customer\"}, {\"_id\": 0, \"password_hash\": 0}).to_list(1000)
    for u in users:
        u[\"order_count\"] = await db.orders.count_documents({\"user_id\": u[\"id\"]})
        agg = await db.orders.aggregate(
            [{\"$match\": {\"user_id\": u[\"id\"], \"payment_status\": \"paid\"}}, {\"$group\": {\"_id\": None, \"sum\": {\"$sum\": \"$total\"}}}]
        ).to_list(1)
        u[\"total_spent\"] = round(agg[0][\"sum\"], 2) if agg else 0
    return users


@api.get(\"/admin/analytics\")
async def admin_analytics(_=Depends(admin_user)):
    total_orders = await db.orders.count_documents({})
    paid_orders = await db.orders.count_documents({\"payment_status\": \"paid\"})
    total_customers = await db.users.count_documents({\"role\": \"customer\"})
    total_products = await db.products.count_documents({})

    rev_agg = await db.orders.aggregate(
        [{\"$match\": {\"payment_status\": \"paid\"}}, {\"$group\": {\"_id\": None, \"revenue\": {\"$sum\": \"$total\"}}}]
    ).to_list(1)
    revenue = round(rev_agg[0][\"revenue\"], 2) if rev_agg else 0

    # Status breakdown
    status_agg = await db.orders.aggregate([{\"$group\": {\"_id\": \"$status\", \"count\": {\"$sum\": 1}}}]).to_list(20)
    status_counts = {s[\"_id\"]: s[\"count\"] for s in status_agg}

    # Top products (by quantity across all paid orders)
    top_agg = await db.orders.aggregate(
        [
            {\"$match\": {\"payment_status\": \"paid\"}},
            {\"$unwind\": \"$items\"},
            {
                \"$group\": {
                    \"_id\": \"$items.product_id\",
                    \"name\": {\"$first\": \"$items.name\"},
                    \"image\": {\"$first\": \"$items.image\"},
                    \"qty\": {\"$sum\": \"$items.quantity\"},
                    \"revenue\": {\"$sum\": {\"$multiply\": [\"$items.price\", \"$items.quantity\"]}},
                }
            },
            {\"$sort\": {\"qty\": -1}},
            {\"$limit\": 5},
        ]
    ).to_list(5)

    # Daily revenue last 7 days
    daily = []
    for i in range(6, -1, -1):
        day = (datetime.now(timezone.utc) - timedelta(days=i)).date().isoformat()
        agg = await db.orders.aggregate(
            [
                {\"$match\": {\"payment_status\": \"paid\", \"created_at\": {\"$regex\": f\"^{day}\"}}},
                {\"$group\": {\"_id\": None, \"rev\": {\"$sum\": \"$total\"}, \"cnt\": {\"$sum\": 1}}},
            ]
        ).to_list(1)
        daily.append({\"date\": day, \"revenue\": round(agg[0][\"rev\"], 2) if agg else 0, \"orders\": agg[0][\"cnt\"] if agg else 0})

    return {
        \"total_orders\": total_orders,
        \"paid_orders\": paid_orders,
        \"total_customers\": total_customers,
        \"total_products\": total_products,
        \"revenue\": revenue,
        \"status_counts\": status_counts,
        \"top_products\": top_agg,
        \"daily\": daily,
    }


